.page {
  min-height: 100vh;
  background: #ffffff;
}
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
}
.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 0;
  margin-right: 16rpx;
}
.back-arrow {
  font-size: 44rpx;
  color: #007aff;
  font-weight: 300;
  line-height: 1;
}
.back-text {
  font-size: 28rpx;
  color: #007aff;
}
.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.list-scroll {
  height: calc(100vh - 150rpx);
}
.method-list {
  padding: 8rpx 0;
}
.method-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: opacity 0.2s;
}
.method-item:active {
  opacity: 0.6;
}
.method-left {
  margin-right: 16rpx;
}
.method-status {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}
.method-status.mastered { background: #34c759; }
.method-status.learning { background: #ff9500; }
.method-status.weak { background: #ff3b30; }
.method-status.untouched { background: #c7c7cc; }
.method-info {
  flex: 1;
}
.method-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
}
.method-desc {
  font-size: 22rpx;
  color: #8e8e93;
  margin-top: 4rpx;
  display: block;
}
.method-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.method-value {
  font-size: 28rpx;
  font-weight: 700;
}
.method-arrow {
  font-size: 24rpx;
  color: #c7c7cc;
}
