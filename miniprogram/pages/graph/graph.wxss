/* ============================================
 * 知识图谱页 · 精密仪表盘式设计
 * 单一主色（iOS 蓝） · 进度环节点 · 纯排版信息
 * ============================================ */

page {
  --bg:            #ffffff;
  --bg-subtle:     #f5f5f7;

  --text-primary:   #1d1d1f;
  --text-secondary: #6e6e73;
  --text-tertiary:  #a1a1a6;

  --accent:        #007aff;
  --accent-soft:   #4a9eff;
  --accent-bg:     rgba(0,122,255,0.06);

  --border:        #d2d2d7;
  --border-soft:   #e5e5ea;

  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,122,255,0.18);

  --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ============================================
 * 页面根
 * ============================================ */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 32rpx;
  padding-top: calc(64rpx + env(safe-area-inset-top));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);
}

.page-leaving {
  opacity: 0;
  transform: translateY(12rpx);
}

.page-enter {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================
 * 顶部学科选择（带背景的胶囊式，强可见性）
 * ============================================ */
.header {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.subject-picker {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  background: var(--bg-subtle);
  transition: transform 0.25s var(--ease-out), opacity 0.25s var(--ease-out);
}

.subject-picker:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.subject-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.arrow {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* ============================================
 * 节点图主区（无包裹卡片，白底直接承载）
 * ============================================ */
.canvas-stage {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
}

.graph-canvas {
  /* 尺寸由 JS 动态设置 */
}

/* ============================================
 * 底部提示
 * ============================================ */
.hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 2rpx;
  margin-top: 24rpx;
  transition: opacity 0.3s var(--ease-out);
}

.hint-hidden {
  opacity: 0;
  pointer-events: none;
}

/* ============================================
 * 聚焦后信息（纯排版浮现，无卡片背景）
 * 信息在底部，与详情按钮分区
 * ============================================ */
.info-floating {
  position: absolute;
  bottom: 200rpx;
  left: 48rpx;
  right: 48rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s var(--ease-out);
  pointer-events: none;
  z-index: 15;
}

.info-floating.show {
  opacity: 1;
  transform: translateY(0);
}

.info-line {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 2rpx;
  font-family: -apple-system, sans-serif;
}

.info-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.info-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  letter-spacing: 1rpx;
  display: block;
}

/* ============================================
 * 查看详情按钮（主 CTA，对齐规范）
 * ============================================ */
.detail-btn {
  position: absolute;
  bottom: 48rpx;
  left: 48rpx;
  right: 48rpx;
  height: 96rpx;
  background: var(--accent);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: var(--shadow-lg);
  transform: translateY(120rpx);
  opacity: 0;
  transition: all 0.4s var(--ease-spring);
  pointer-events: none;
  z-index: 20;
}

.detail-btn::after {
  border: none;
}

.detail-btn.show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.detail-btn:active {
  transform: scale(0.98);
  opacity: 0.92;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.12);
}

.btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.btn-arrow {
  color: #fff;
  font-size: 32rpx;
  opacity: 0.7;
  transition: transform 0.3s var(--ease-out);
}

.detail-btn:active .btn-arrow {
  transform: translateX(8rpx);
}

/* ============================================
 * 聚焦遮罩（柔和白雾）
 * ============================================ */
.zoom-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0);
  pointer-events: none;
  z-index: 10;
  transition: background 0.4s var(--ease-out);
}

.zoom-overlay.show {
  background: rgba(255,255,255,0.75);
  pointer-events: auto;
}

/* ============================================
 * 入场动画
 * ============================================ */
@keyframes reveal-up {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.reveal { animation: reveal-up 0.4s var(--ease-out) both; }
.reveal-1 { animation-delay: 0.04s; }
.reveal-2 { animation-delay: 0.10s; }
.reveal-3 { animation-delay: 0.16s; }
