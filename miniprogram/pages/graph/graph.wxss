.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
}
.header {
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}
.subject-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.subject-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: 0.5rpx;
}
.arrow {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 4rpx;
}
.canvas-wrapper {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}
.graph-canvas {
  width: 100%;
  height: 100%;
}

/* 查看详情按钮 */
.detail-btn {
  position: absolute;
  bottom: 120rpx;
  left: 80rpx;
  right: 80rpx;
  height: 88rpx;
  background: #007aff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.35);
  transform: translateY(120rpx);
  opacity: 0;
  transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  z-index: 20;
}
.detail-btn.show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}
.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}
.btn-arrow {
  font-size: 28rpx;
  color: #ffffff;
  opacity: 0.7;
}

/* 聚焦模式遮罩 */
.zoom-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0;
  pointer-events: none;
  z-index: 10;
}
.zoom-overlay.show {
  opacity: 1;
  pointer-events: auto;
}
