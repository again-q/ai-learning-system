<view class="page">
  <!-- 顶部学科选择 -->
  <view class="header">
    <picker bindchange="changeSubject" value="{{subjectIndex}}" range="{{subjects}}">
      <view class="subject-picker">
        <text class="subject-text">{{currentSubject}}</text>
        <text class="arrow">▾</text>
      </view>
    </picker>
  </view>

  <!-- 画布区域 -->
  <view class="canvas-wrapper">
    <canvas class="graph-canvas" type="2d" id="graphCanvas" 
            bindtouchstart="onCanvasTap"></canvas>
    
    <!-- 查看详情按钮（缩放后出现） -->
    <view class="detail-btn {{showDetailBtn ? 'show' : ''}}" bindtap="goDetail">
      <text class="btn-text">查看详情</text>
      <text class="btn-arrow">▸</text>
    </view>

    <!-- 聚焦模式指示 -->
    <view class="zoom-hint {{isZoomed ? 'show' : ''}}">
      <text class="hint-text">点击空白处返回</text>
    </view>
  </view>
</view>
