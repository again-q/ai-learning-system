.container {
  min-height: 100vh;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx 80rpx;
}

/* 顶部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 80rpx;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007aff;
  border-radius: 70rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,122,255,0.3);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-top: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8e8e93;
}

/* 头像 */
.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

/* 头像按钮 - 彻底重置所有 button 默认样式 */
.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 0 !important;
  background: #f0f0f5 !important;
  border: none !important;
  outline: none;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 80rpx;
}

.avatar-btn::after {
  border: none !important;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  display: block;
  border-radius: 80rpx;
  border: 4rpx solid #e5e5ea;
  box-sizing: border-box;
}

.nickname {
  text-align: center;
  font-size: 32rpx;
  color: #1d1d1f;
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  width: 60%;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 底部 */
.footer {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #007aff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.3);
}

.login-btn:active { opacity: 0.85; transform: scale(0.98); }
.login-btn::after { border: none; }

.btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.hint {
  font-size: 22rpx;
  color: #c7c7cc;
}
