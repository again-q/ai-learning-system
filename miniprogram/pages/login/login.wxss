/* ============================================
 * AI 学习助手 · 登录页
 * 风格：Apple/Notion 极简白色简约
 * 重点：流畅的微交互与过渡动画
 * ============================================ */

page {
  --bg:            #ffffff;
  --bg-subtle:     #f5f5f7;

  --text-primary:   #1d1d1f;
  --text-secondary: #6e6e73;
  --text-tertiary:  #a1a1a6;

  --accent:        #007aff;
  --accent-soft:   #4a9eff;
  --accent-bg:     rgba(0,122,255,0.06);

  --border:        #d2d2d7;
  --border-soft:   #e5e5ea;

  --shadow-sm: 0 1rpx 2rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,122,255,0.18);

  --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
}

/* ---------- 页面根 ---------- */
.page {
  min-height: 100vh;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 64rpx 48rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* ============================================
 * 品牌区
 * ============================================ */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.brand-mark {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  background: var(--accent);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-lg);
  transition: transform 0.4s var(--ease-spring);
  overflow: hidden;
}

.brand-mark:active {
  transform: scale(0.92);
}

/* 按压时的涟漪扩散 */
.brand-mark__ripple {
  position: absolute;
  inset: 0;
  border-radius: 32rpx;
  background: radial-gradient(circle at center, rgba(255,255,255,0.4) 0%, transparent 60%);
  opacity: 0;
  transform: scale(0.5);
  pointer-events: none;
}

.brand-mark:active .brand-mark__ripple {
  animation: ripple 0.6s var(--ease-out);
}

@keyframes ripple {
  0%   { opacity: 0.6; transform: scale(0.5); }
  100% { opacity: 0;   transform: scale(1.5); }
}

.brand-mark__symbol {
  font-size: 64rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.brand-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

/* ============================================
 * 资料区
 * ============================================ */
.profile {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

/* ---------- 头像 ---------- */
.avatar-btn {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  padding: 0 !important;
  margin: 0 !important;
  margin-bottom: 40rpx;
  line-height: 0 !important;
  background: transparent !important;
  border: none !important;
  outline: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: transform 0.3s var(--ease-out);
}

.avatar-btn::after {
  border: none !important;
}

.avatar-btn:active {
  transform: scale(0.94);
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  display: block;
  border-radius: 50%;
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-soft);
  box-sizing: border-box;
  transition: transform 0.4s var(--ease-spring);
}

/* 选择头像后的弹跳动画 */
.avatar--pop {
  animation: avatar-pop 0.5s var(--ease-spring);
}

@keyframes avatar-pop {
  0%   { transform: scale(0.8); opacity: 0.4; }
  60%  { transform: scale(1.08); }
  100% { transform: scale(1); opacity: 1; }
}

/* 头像外圈光环（聚焦暗示） */
.avatar-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
  pointer-events: none;
  transition: border-color 0.4s var(--ease-out);
}

.avatar-btn:active .avatar-ring {
  border-color: rgba(0,122,255,0.3);
}

/* ---------- 昵称输入 ---------- */
.nickname-wrap {
  position: relative;
  width: 80%;
  max-width: 480rpx;
}

.nickname-input {
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 20rpx 0;
  background: transparent;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: transform 0.3s var(--ease-out);
}

.nickname-placeholder {
  color: var(--text-tertiary);
  font-weight: 400;
}

.nickname-wrap:focus-within .nickname-input {
  transform: translateY(-2rpx);
}

.nickname-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 2rpx;
  background: var(--border);
  transition: all 0.45s var(--ease-out);
}

.nickname-wrap:focus-within .nickname-line {
  width: 100%;
  background: var(--accent);
  box-shadow: 0 0 8rpx rgba(0,122,255,0.3);
}

/* ============================================
 * 行动区
 * ============================================ */
.action {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: var(--accent);
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  transition: all 0.25s var(--ease-out);
  position: relative;
  overflow: hidden;
}

.login-btn::after {
  border: none;
}

/* 按钮光泽扫过（hover/active 时触发） */
.login-btn__shimmer {
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  pointer-events: none;
}

.login-btn:active .login-btn__shimmer {
  animation: shimmer 0.6s var(--ease-out);
}

@keyframes shimmer {
  0%   { left: -100%; }
  100% { left: 100%; }
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.92;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.12);
}

.login-btn[disabled] {
  background: var(--bg-subtle);
  color: var(--text-tertiary);
  box-shadow: none;
}

.login-btn[disabled] .login-btn__shimmer {
  display: none;
}

.login-btn__content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.login-btn__text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.login-btn__arrow {
  color: #fff;
  font-size: 32rpx;
  font-weight: 400;
  transition: transform 0.3s var(--ease-out);
}

.login-btn:active .login-btn__arrow {
  transform: translateX(8rpx);
}

/* 加载态：按钮变窄 + 显示 spinner */
.login-btn--loading {
  background: var(--accent-soft);
  pointer-events: none;
}

.login-btn--loading .login-btn__text {
  font-size: 30rpx;
  opacity: 0.9;
}

/* Spinner */
.spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============================================
 * 入场动画（压缩版，避免加载感慢）
 * ============================================ */
@keyframes reveal-up {
  0% {
    opacity: 0;
    transform: translateY(20rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.reveal {
  animation: reveal-up 0.45s var(--ease-out) both;
}

.reveal-1 { animation-delay: 0.05s; }
.reveal-2 { animation-delay: 0.11s; }
.reveal-3 { animation-delay: 0.17s; }
.reveal-4 { animation-delay: 0.23s; }
.reveal-5 { animation-delay: 0.29s; }
.reveal-6 { animation-delay: 0.35s; }

/* ============================================
 * 适配：小屏设备
 * ============================================ */
@media (max-height: 667px) {
  .brand {
    margin-bottom: 64rpx;
  }
  .brand-mark {
    width: 112rpx;
    height: 112rpx;
    margin-bottom: 24rpx;
  }
  .brand-mark__symbol {
    font-size: 56rpx;
  }
  .brand-title {
    font-size: 40rpx;
  }
  .profile {
    margin-bottom: 64rpx;
  }
  .avatar-btn, .avatar {
    width: 112rpx;
    height: 112rpx;
  }
}
