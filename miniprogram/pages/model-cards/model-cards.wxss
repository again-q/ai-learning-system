.page {
  min-height: 100vh;
  background: #f5f5f7;
}
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}
.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 0;
  margin-right: 16rpx;
}
.back-arrow {
  font-size: 44rpx;
  color: #007aff;
  font-weight: 300;
  line-height: 1;
}
.back-text {
  font-size: 28rpx;
  color: #007aff;
}
.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.card-scroll {
  height: calc(100vh - 150rpx);
  padding: 24rpx 20rpx;
}
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.model-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
  position: relative;
  overflow: hidden;
}
.model-card:active {
  transform: scale(0.97);
}
.card-status {
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
}
.card-status.mastered { background: #34c759; }
.card-status.learning { background: #ff9500; }
.card-status.weak { background: #ff3b30; }
.card-status.untouched { background: #c7c7cc; }
.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
  margin-bottom: 8rpx;
}
.card-desc {
  font-size: 22rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.card-value {
  font-size: 32rpx;
  font-weight: 700;
}
.card-label {
  font-size: 22rpx;
  color: #aeaeb2;
}
