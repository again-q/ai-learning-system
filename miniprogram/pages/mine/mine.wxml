<view class="container {{pageReady ? 'page-enter' : 'page-leaving'}}">
  <!-- 个人信息 -->
  <view class="profile-section">
    <block wx:if="{{!isLoggedIn}}">
      <view class="avatar-placeholder">👤</view>
      <text class="nickname">未登录</text>
      <view class="login-btn" bindtap="goLogin">点击登录</view>
    </block>
    <block wx:else>
      <image class="avatar" src="{{avatarUrl || '/images/avatar.png'}}"></image>
      <text class="nickname">{{nickName}}</text>
      <text class="streak">🔥 学习第 {{streak}} 天</text>
    </block>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card">
    <view class="stat {{isLoggedIn ? '' : 'dim'}}">
      <text class="stat-num">{{isLoggedIn ? todayMinutes : '--'}}</text>
      <text class="stat-label">今日学习(分钟)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat {{isLoggedIn ? '' : 'dim'}}">
      <text class="stat-num">{{isLoggedIn ? learnedNodes : '--'}}</text>
      <text class="stat-label">已学知识点</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat {{isLoggedIn ? '' : 'dim'}}">
      <text class="stat-num">{{isLoggedIn ? totalMastery + '%' : '--'}}</text>
      <text class="stat-label">总掌握度</text>
    </view>
  </view>

  <!-- 学科进度 -->
  <view class="section" wx:if="{{isLoggedIn && subjects.length > 0}}">
    <text class="section-title">📚 学科进度</text>
    <view class="subject-list">
      <view class="subject-row" wx:for="{{subjects}}" wx:key="*this">
        <text class="subject-name">{{item.name}}</text>
        <view class="progress-bg">
          <view class="progress-fill" style="width: {{item.mastery}}%"></view>
        </view>
        <text class="subject-pct">{{item.mastery}}%</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item {{isLoggedIn ? '' : 'dim'}}" bindtap="goSetting">
      <image class="menu-icon" src="/images/shezhi.png"></image>
      <text class="menu-text">知识管理</text>
      <text class="menu-arrow">▸</text>
    </view>
    <view class="menu-item {{isLoggedIn ? '' : 'dim'}}" bindtap="goReport">
      <image class="menu-icon" src="/images/baogao.png"></image>
      <text class="menu-text">学习报告</text>
      <text class="menu-arrow">▸</text>
    </view>
    <view class="menu-item {{isLoggedIn ? '' : 'dim'}}" bindtap="goAchievement">
      <image class="menu-icon" src="/images/chengjiu.png"></image>
      <text class="menu-text">成就墙</text>
      <text class="menu-arrow">▸</text>
    </view>
  </view>
</view>
