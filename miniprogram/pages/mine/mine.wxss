.container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 120rpx 28rpx 40rpx;
}

/* 个人信息 */
.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #e5e5ea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 16rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 6rpx;
}

.streak {
  font-size: 24rpx;
  color: #8e8e93;
}

.login-btn {
  background: #007aff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.login-btn:active { opacity: 0.85; }

/* 学习统计 */
.stats-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat.dim { opacity: 0.5; }

.stat-num {
  font-size: 42rpx;
  font-weight: 700;
  color: #007aff;
}

.stat-label {
  font-size: 22rpx;
  color: #8e8e93;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f5;
}

/* 学科进度 */
.section { margin-bottom: 28rpx; }

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 14rpx;
}

.subject-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.subject-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.subject-row + .subject-row { border-top: 2rpx solid #f5f5f7; }

.subject-name {
  width: 72rpx;
  font-size: 26rpx;
  color: #1d1d1f;
  font-weight: 500;
}

.progress-bg {
  flex: 1;
  height: 14rpx;
  background: #f0f0f5;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #007aff, #00c6ff);
  border-radius: 7rpx;
}

.subject-pct {
  width: 56rpx;
  font-size: 22rpx;
  color: #8e8e93;
  text-align: right;
}

/* 功能菜单 */
.menu-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 20rpx;
}

.menu-item + .menu-item { border-top: 2rpx solid #f5f5f7; }

.menu-item.dim { opacity: 0.35; }

.menu-item:active:not(.dim) { background: #f5f5f7; }

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1d1d1f;
}

.menu-arrow {
  font-size: 28rpx;
  color: #c7c7cc;
}
