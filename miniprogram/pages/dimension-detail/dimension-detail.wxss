.page {
  min-height: 100vh;
  background: #f5f5f7;
}
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  background: #ffffff;
  border-bottom: 1rpx solid #e5e5e7;
}
.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 0;
}
.back-arrow {
  font-size: 44rpx;
  color: #007aff;
  font-weight: 300;
  line-height: 1;
}
.back-text {
  font-size: 28rpx;
  color: #007aff;
}
.header-center {
  flex: 1;
  text-align: center;
}
.header-subject {
  font-size: 26rpx;
  color: #8e8e93;
  display: block;
}
.header-dim {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
}
.header-right {
  min-width: 80rpx;
  text-align: right;
}
.header-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #007aff;
}
.layer-list {
  margin: 24rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.layer-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: opacity 0.2s;
}
.layer-item:last-child {
  border-bottom: none;
}
.layer-item:active {
  opacity: 0.6;
}
.layer-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.layer-emoji {
  font-size: 34rpx;
}
.layer-info {
  flex: 1;
}
.layer-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
}
.layer-desc {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 4rpx;
  display: block;
}
.layer-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.layer-value {
  font-size: 30rpx;
  font-weight: 700;
}
.layer-arrow {
  font-size: 28rpx;
  color: #c7c7cc;
}
.footer {
  text-align: center;
  padding: 32rpx;
}
.footer-text {
  font-size: 22rpx;
  color: #aeaeb2;
  display: block;
  line-height: 1.8;
}
