<view class="container">
  <!-- 顶部问候 -->
  <view class="top-section">
    <view class="greeting-row">
      <text class="greeting">👋 早上好，{{userName}}</text>
    </view>
  </view>

  <!-- 学科切换 -->
  <view class="subject-section">
    <view class="subject-row">
      <text class="arrow-btn" bindtap="prevSubject">◀</text>
      <view class="subject-center">
        <text class="subject-name">{{currentSubject}}</text>
      </view>
      <text class="arrow-btn" bindtap="nextSubject">▶</text>
    </view>
  </view>

  <!-- 学习统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{todayMinutes}}</text>
      <text class="stat-unit">分钟</text>
      <text class="stat-label">今日学习</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{streak}}</text>
      <text class="stat-unit">天</text>
      <text class="stat-label">连续学习</text>
    </view>
  </view>

  <!-- 掌握度环形图 -->
  <view class="mastery-section">
    <view class="ring-container">
      <canvas class="ring-canvas" canvas-id="masteryRing" type="2d"></canvas>
      <view class="ring-center">
        <text class="ring-pct">{{mastery}}%</text>
        <text class="ring-label">{{currentSubject}}掌握度</text>
      </view>
    </view>
  </view>

  <!-- 今日建议 -->
  <view class="suggestion-section">
    <text class="suggestion-title">📋 今日建议</text>
    <view class="suggestion-card">
      <text class="suggestion-text">{{suggestion}}</text>
    </view>
  </view>

  <!-- 开始学习 -->
  <view class="action-section">
    <view class="start-btn" bindtap="goStudy">
      <text class="start-text">开始学习</text>
    </view>
  </view>
</view>
