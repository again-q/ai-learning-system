.container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 160rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* 顶部问候 */
.top-section {
  margin-bottom: 36rpx;
}

.greeting-row {
  display: flex;
  justify-content: center;
}

.greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
}

/* 学科切换 */
.subject-section {
  margin-bottom: 36rpx;
}

.subject-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.arrow-btn {
  font-size: 36rpx;
  color: #c7c7cc;
  padding: 20rpx;
}

.arrow-btn:active { color: #007aff; }

.subject-center {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.subject-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #1d1d1f;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #007aff;
}

.stat-unit {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: -4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8e8e93;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #f0f0f5;
}

/* 环形图 */
.mastery-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.ring-container {
  position: relative;
  width: 320rpx;
  height: 320rpx;
}

.ring-canvas {
  width: 320rpx;
  height: 320rpx;
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ring-pct {
  font-size: 68rpx;
  font-weight: 700;
  color: #007aff;
}

.ring-label {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 6rpx;
}

/* 建议 */
.suggestion-section {
  margin-bottom: 36rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 16rpx;
}

.suggestion-card {
  background: #fff;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.suggestion-text {
  font-size: 28rpx;
  color: #1d1d1f;
  line-height: 1.7;
}

/* 按钮 */
.action-section {
  margin-top: auto;
  padding-top: 20rpx;
}

.start-btn {
  background: #007aff;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0,122,255,0.3);
}

.start-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.start-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}
