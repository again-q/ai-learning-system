<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-text">‹ 我的</text>
    </view>
    <text class="header-title">知识管理</text>
    <view class="header-spacer"></view>
  </view>

  <!-- 学科选择 -->
  <view class="toolbar">
    <picker bindchange="changeSubject" value="{{subjectIndex}}" range="{{subjects}}">
      <view class="subject-picker">
        <text class="subject-text">{{currentSubject}}</text>
        <text class="arrow">▾</text>
      </view>
    </picker>
    <view class="add-btn" bindtap="openAdd">+ 新增</view>
  </view>

  <!-- 类型筛选 -->
  <view class="filters">
    <view class="filter {{typeFilter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">全部</view>
    <view class="filter {{typeFilter === 'concept' ? 'active' : ''}}" bindtap="setFilter" data-type="concept">概念</view>
    <view class="filter {{typeFilter === 'model' ? 'active' : ''}}" bindtap="setFilter" data-type="model">模型</view>
    <view class="filter {{typeFilter === 'skill' ? 'active' : ''}}" bindtap="setFilter" data-type="skill">技能</view>
  </view>

  <!-- 列表 -->
  <scroll-view class="list" scroll-y="true">
    <view class="node-item" wx:for="{{nodes}}" wx:key="_id" data-node="{{item}}" bindtap="openEdit">
      <view class="node-left">
        <view class="status-dot" style="background:{{getColor(item.mastery)}}"></view>
        <view class="node-info">
          <text class="node-name">{{item.name}}</text>
          <text class="node-meta">{{getTypeName(item.type)}} · {{item.chapter || '未分类'}}</text>
        </view>
      </view>
      <view class="node-right">
        <text class="node-mastery" style="color:{{getColor(item.mastery)}}">{{item.mastery}}%</text>
        <view class="del-btn" bindtap="deleteNode" data-node="{{item}}" catchtap>✕</view>
      </view>
    </view>
    <view class="empty" wx:if="{{nodes.length === 0 && !loading}}">暂无数据，点击 + 新增</view>
  </scroll-view>

  <!-- 编辑表单弹窗 -->
  <view class="overlay {{showForm ? 'show' : ''}}" bindtap="closeForm">
    <view class="form-card" catchtap="{{true}}">
      <view class="form-header">
        <text class="form-title">{{editNode ? '编辑' : '新增'}}知识点</text>
        <text class="form-close" bindtap="closeForm">✕</text>
      </view>
      <view class="form-body">
        <view class="field">
          <text class="field-label">名称</text>
          <input class="field-input" placeholder="输入知识点名称" value="{{formData.name}}" bindinput="onFormInput" data-field="name"/>
        </view>
        <view class="field">
          <text class="field-label">类型</text>
          <picker bindchange="onTypeChange" value="{{['concept','model','skill'].indexOf(formData.type)}}" range="{{['概念','模型','技能']}}">
            <view class="field-picker">{{formData.typeName}}</view>
          </picker>
        </view>
        <view class="field">
          <text class="field-label">章节</text>
          <input class="field-input" placeholder="如 必修1-第三章" value="{{formData.chapter}}" bindinput="onFormInput" data-field="chapter"/>
        </view>
        <view class="field">
          <text class="field-label">难度 0~1</text>
          <input class="field-input" placeholder="0.5" value="{{formData.difficulty}}" bindinput="onFormInput" data-field="difficulty"/>
        </view>
        <view class="field">
          <text class="field-label">前置依赖</text>
          <input class="field-input" placeholder="节点ID，逗号分隔" value="{{formData.deps}}" bindinput="onFormInput" data-field="deps"/>
        </view>
      </view>
      <view class="form-actions">
        <view class="btn-cancel" bindtap="closeForm">取消</view>
        <view class="btn-save" bindtap="saveNode">保存</view>
      </view>
    </view>
  </view>
</view>
